{
  "expo": {
    "name": "TaskHub",
    "slug": "taskhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon (1).png",
    "scheme": "taskhub",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskhub.app"
    },
    "android": {
      "package": "com.taskhub.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon (1).png",
        "backgroundColor": "#0B4A7D"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "taskhub"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B4A7D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon (1).png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B4A7D"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "packagingOptions": {
              "abiFilters": [
                "arm64-v8a"
              ]
            },
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51ed36f2-3eba-4fb3-9e19-877213b9db70"
      }
    },
    "owner": "desire-coder"
  }
}